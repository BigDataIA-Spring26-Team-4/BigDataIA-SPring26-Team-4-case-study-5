# ============================================================================
# PE Org-AI-R Platform - Environment Configuration
# ============================================================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Fill in your actual values
# 3. Never commit .env to git (it's in .gitignore)
#
# ============================================================================

# ============================================================================
# Application Settings
# ============================================================================
APP_NAME="PE Org-AI-R Platform"
APP_VERSION="1.0.0"
DEBUG=false

# ============================================================================
# Snowflake Database Configuration
# ============================================================================
# REQUIRED: Get these from your Snowflake account
# Format: <account_identifier>.<region>
# Example: xy12345.us-east-1 or xy12345.east-us-2.azure
SNOWFLAKE_ACCOUNT=your_account_identifier_here

# Your Snowflake username
SNOWFLAKE_USER=your_username_here

# Your Snowflake password
SNOWFLAKE_PASSWORD=your_password_here

# Database, schema, and warehouse names (defaults are provided)
SNOWFLAKE_DATABASE=PE_ORG_AIR_DB
SNOWFLAKE_SCHEMA=PE_ORG_AIR_SCHEMA
SNOWFLAKE_WAREHOUSE=PE_ORG_AIR_WH

# Optional: Snowflake role
# SNOWFLAKE_ROLE=ACCOUNTADMIN

# ============================================================================
# Redis Cache Configuration
# ============================================================================
# For local development, use localhost
# For Docker, use the service name: redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_ENABLED=true

# Optional: Redis password (if authentication is enabled)
# REDIS_PASSWORD=your_redis_password

# Cache TTL settings (in seconds)
CACHE_TTL_COMPANY=300          # 5 minutes
CACHE_TTL_INDUSTRY=3600        # 1 hour
CACHE_TTL_ASSESSMENT=120       # 2 minutes
CACHE_TTL_DIMENSION_WEIGHTS=86400  # 24 hours

# ============================================================================
# AWS S3 Configuration
# ============================================================================
# OPTIONAL: Only needed if you want to store documents in S3
S3_ENABLED=false

# AWS credentials (not needed if using IAM roles)
# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# AWS region
AWS_REGION=us-east-1

# S3 bucket name for document storage
# S3_BUCKET_NAME=pe-org-air-documents

# ============================================================================
# API Configuration
# ============================================================================
API_V1_PREFIX=/api/v1
PAGINATION_DEFAULT_PAGE_SIZE=20
PAGINATION_MAX_PAGE_SIZE=100

# ============================================================================
# Logging Configuration
# ============================================================================
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# QUICK START CHECKLIST
# ============================================================================
# 
# For local development (minimum required):
# ✓ SNOWFLAKE_ACCOUNT
# ✓ SNOWFLAKE_USER
# ✓ SNOWFLAKE_PASSWORD
# ✓ REDIS_HOST=localhost (if Redis is running locally)
#
# For Docker deployment:
# ✓ All Snowflake settings
# ✓ REDIS_HOST=redis (use Docker service name)
# ✓ Optionally configure S3 if needed
#
# ============================================================================
PATENTSVIEW_API_KEY=your_patentsview_api_key_here

# ============================================================================
# CS3: External Data APIs
# ============================================================================
# RapidAPI key for Real-Time Glassdoor Data (free tier: ~500 req/month)
# Sign up at https://rapidapi.com/letscrape-6bRBa3QguO5/api/real-time-glassdoor-data
# Wextractor auth token for Glassdoor reviews (preferred, cleanest API)
# Sign up at https://wextractor.com/account/signup — free credits on signup
WEXTRACTOR_TOKEN=your_wextractor_token_here

# RapidAPI key for Real-Time Glassdoor Data (fallback)
# Sign up at https://rapidapi.com/letscrape-6bRBa3QguO5/api/real-time-glassdoor-data
RAPIDAPI_KEY=your_rapidapi_key_here

# sec-api.io key for Directors & Board Members data (free tier available)
# Sign up at https://sec-api.io/signup
SEC_API_KEY=your_sec_api_key_here
# GNews.io API key (free tier: 100 requests/day)
# Sign up at https://gnews.io → get your API key
GNEWS_API_KEY=your_gnews_api_key_here

# ============================================================================
# CS4: RAG & Search Configuration
# ============================================================================
# LLM Provider (any LiteLLM-compatible model string)
# Examples:
#   OpenAI:    gpt-4o, gpt-4o-mini
#   Anthropic: claude-sonnet-4-20250514, claude-haiku-4-5-20251001
#   Ollama:    ollama/llama3, ollama/mistral
#   Together:  together_ai/meta-llama/Llama-3-70b
CS4_PRIMARY_MODEL=
CS4_FALLBACK_MODEL=

# Optional: task-specific overrides (fall back to PRIMARY if not set)
# CS4_EXTRACTION_MODEL=
# CS4_JUSTIFICATION_MODEL=
# CS4_CHAT_MODEL=

# Daily LLM spend limit (USD)
CS4_DAILY_BUDGET_USD=50.0

# Retrieval tuning
CS4_DENSE_WEIGHT=0.6
CS4_BM25_WEIGHT=0.4
CS4_RRF_K=60

# Embedding model (any sentence-transformers model)
CS4_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ChromaDB persistence directory
CS4_CHROMA_PERSIST_DIR=./chroma_data

# CS3 API base URL (where CS1/CS2/CS3 endpoints live)
CS4_CS3_API_URL=http://localhost:8000

# Provider API keys (set whichever provider you're using)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OLLAMA_API_BASE=http://localhost:11434