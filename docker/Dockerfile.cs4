# Dockerfile for CS4 RAG & Search API
# Serves the CS4 API on port 8003 with ChromaDB + sentence-transformers
FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc g++ curl \
    && rm -rf /var/lib/apt/lists/*

# Copy dependency files
COPY pyproject.toml poetry.lock* ./

# Install Python dependencies (no Poetry in Docker — export to requirements)
RUN pip install poetry==2.2.1 poetry-plugin-export && \
    poetry export -f requirements.txt --output requirements.txt --without-hashes && \
    pip install -r requirements.txt && \
    pip install chromadb litellm && \
    rm -rf /root/.cache/pip

# Pre-download the sentence-transformers embedding model so it's cached in the image
RUN python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('all-MiniLM-L6-v2')"

# Copy application code (CS3 app/ needed for rubric fallback + CS4 src/)
COPY app/ /app/app/
COPY src/ /app/src/
COPY cs4_api.py /app/cs4_api.py

# Copy results for local fallback scoring data
COPY results/ /app/results/

# Copy evidence data files (Glassdoor, Board, News, Jobs cache)
COPY data/ /app/data/

# Create directories for runtime data
RUN mkdir -p /app/chroma_data

# Create non-root user
RUN useradd -m -u 1000 appuser && \
    chown -R appuser:appuser /app

USER appuser

EXPOSE 8003

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:8003/health || exit 1

CMD ["uvicorn", "cs4_api:app", "--host", "0.0.0.0", "--port", "8003"]
